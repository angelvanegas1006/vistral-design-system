  "scripts": {
    "prepare": "husky",
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "analyze": "tsx scripts/analyze-bundle.ts",
    "setup": "bash scripts/dev-setup.sh",
    "figma:test": "tsx scripts/test-figma-connection.ts",
    "figma:sync:tokens": "tsx scripts/sync-figma.ts tokens",
    "figma:sync:components": "tsx scripts/sync-figma.ts components",
    "figma:sync:all": "tsx scripts/sync-figma.ts all",
    "tokens:generate": "tsx lib/generators/token-generator.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
